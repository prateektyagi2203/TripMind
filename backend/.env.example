# Copy this file to `.env` and fill in your key. NEVER commit `.env`.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
# Comma-separated list of allowed CORS origins for the Flutter dev client.
CORS_ORIGINS=http://localhost,http://localhost:8080,http://127.0.0.1:8080
# AeroDataBox (RapidAPI) key for live flight status. Get a free key at
# https://rapidapi.com/aedbx-aedbx/api/aerodatabox
RAPIDAPI_KEY=
# Optional: how often (hours) the scheduler refreshes flights within 24h.
FLIGHT_REFRESH_HOURS=3
